# ─── Flask ───────────────────────────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# ─── Database ─────────────────────────────────────────────────────────────────
# Neon DB (PostgreSQL) connection string — from your Neon dashboard
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Default admin credentials (change before deploying!) ────────────────────
ADMIN_PASSWORD=Admin@1234
VIEWER_PASSWORD=Viewer@1234

# ─── Optional ─────────────────────────────────────────────────────────────────
# Only used when DATABASE_URL is not set (local dev SQLite fallback)
SQLITE_PATH=log_analyzer.db
